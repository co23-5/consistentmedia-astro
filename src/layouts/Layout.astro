---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Consistent Media macht Expertise sichtbar. Über YouTube, Content und Ads für Experten, die fachlich stark sind und online gefunden werden wollen.",
} = Astro.props;

const fullTitle = title === "Consistent Media"
  ? title
  : `${title} | Consistent Media`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/ClashDisplay-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-black text-white">
    <slot />
  </body>
</html>
