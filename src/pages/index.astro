---
import Layout from "../layouts/Layout.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import CTA from "../components/CTA.astro";
import { social } from "../lib/social";

const paths = [
  {
    title: "Ich bin Experte, aber online unsichtbar",
    text: "Du hast die Kompetenz, aber keinen Kanal und keine Reichweite. Wir zeigen dir, wie Sichtbarkeit von Grund auf entsteht.",
    href: "/methode",
  },
  {
    title: "Ich produziere schon, aber es kommen keine Anfragen",
    text: "Content ohne System verpufft. Wir machen aus einzelnen Videos einen Weg, der zu echten Anfragen führt.",
    href: "/methode",
  },
  {
    title: "Ich will meine Sichtbarkeit ausbauen",
    text: "Es läuft, aber du willst mehr erreichen oder es abgeben. Wir übernehmen Strategie und Produktion.",
    href: "/leistungen",
  },
];

const steps = [
  { n: "01", title: "Strategie und Kanalaufbau", text: "Positionierung, Themen, Format. Das Fundament, auf dem alles steht." },
  { n: "02", title: "Content-Produktion", text: "Videos, die deine Expertise klar zeigen. Konstant, in hoher Qualität." },
  { n: "03", title: "Distribution und Ads", text: "Damit die richtigen Menschen deine Inhalte sehen, nicht nur der Zufall." },
  { n: "04", title: "Anfragen und Conversion", text: "Aus Sichtbarkeit werden Vertrauen und am Ende konkrete Anfragen." },
];

const outcomes = [
  "Vorqualifizierte Anfragen",
  "Konstante Sichtbarkeit",
  "Weniger Fragen, mehr System",
];
---

<Layout
  title="Consistent Media"
  description="Die Besten sollten gewinnen, nicht die Lautesten. Wir machen echte Expertise sichtbar, über YouTube, Content und Ads."
>
  <!-- 1. Hero: das Warum, mit Studio-Video im Hintergrund -->
  <section class="relative -mt-[73px] flex min-h-[100svh] flex-col justify-center overflow-hidden border-b border-white/10 px-6 pb-24 pt-[73px] md:px-8">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 hidden h-full w-full object-cover md:block"
    >
      <source src="/consistent-media-studio-header.mp4" type="video/mp4" />
    </video>
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
    >
      <source src="/consistent-media-studio-header-hochkant.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/40"></div>

    <div class="relative mx-auto w-full max-w-content">
      <h1 class="font-display max-w-4xl text-5xl font-semibold leading-[1.05] tracking-tight md:text-6xl lg:text-7xl">
        Nicht mehr Kunden.<br />Die <span class="text-brand-green">richtigen.</span>
      </h1>
      <p class="mt-10 max-w-xl text-lg leading-relaxed text-white/80 md:text-xl">
        Dein Kalender ist voll, aber Anfrage ist nicht gleich Anfrage. Wir
        machen deine Expertise sichtbar, damit genau die Menschen zu dir kommen,
        für die du die beste Lösung bist.
      </p>
      <div class="mt-14 flex flex-wrap items-center gap-4">
        <a
          href="/kontakt"
          class="border border-brand-green bg-brand-green px-8 py-4 text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          Zusammenarbeit anfragen
        </a>
        <a
          href="/methode"
          class="border border-white/40 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white/70"
        >
          So funktioniert es
        </a>
      </div>
    </div>
  </section>

  <!-- 2. Manifest: das Herzstück, auf Notizblock-Raster -->
  <section class="paper-grid border-b border-white/10 px-6 py-28 md:px-8 md:py-40">
    <div class="mx-auto max-w-3xl">
      <p class="mb-12 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Warum wir das tun
      </p>
      <div class="space-y-8 text-xl leading-relaxed text-white/70 md:text-2xl md:leading-relaxed">
        <p>
          Jeden Tag entscheiden sich Menschen für einen Anbieter, der schlechter
          ist. Und die wahren Experten, die es besser könnten, wurden nicht
          gefunden.
        </p>
        <p>
          Das ist ein Verlust auf allen Seiten. Für den Experten und für den
          Menschen, der diese Hilfe gebraucht hätte, aber nicht gefunden hat.
        </p>
        <p>Deshalb ist unsere Mission:</p>
      </div>
      <p class="font-display mt-10 whitespace-nowrap font-semibold leading-none text-[clamp(1.35rem,6vw,3.25rem)]">
        Expertise <span class="reveal-word text-brand-green">sichtbar</span> machen.
      </p>
    </div>
  </section>

  <script>
    const word = document.querySelector(".reveal-word");
    if (word) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              word.classList.add("is-visible");
              io.disconnect();
            }
          });
        },
        { threshold: 0.6 },
      );
      io.observe(word);
    }
  </script>

  <!-- 3. Der Weg / Methode: das Wie -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Wie wir das tun
      </p>
      <h2 class="font-display mb-6 max-w-2xl text-3xl font-semibold leading-tight md:text-4xl">
        So wird aus Können Sichtbarkeit.
      </h2>
      <p class="mb-16 max-w-xl text-lg leading-relaxed text-white/55">
        Sichtbarkeit ist kein Zufall, sondern ein System. Wir zeigen dir den
        kompletten Weg offen, ehrlich genug, dass du ihn selbst gehen könntest.
      </p>
      <div class="grid gap-px bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s) => (
            <div class="flex flex-col gap-4 bg-black p-8 md:p-10">
              <span class="font-display text-2xl font-semibold text-brand-green">{s.n}</span>
              <h3 class="font-display text-base font-semibold leading-snug">{s.title}</h3>
              <p class="leading-relaxed text-white/55">{s.text}</p>
            </div>
          ))
        }
      </div>
      <a href="/methode" class="mt-12 inline-block text-sm font-semibold text-brand-green hover:underline">
        Die ganze Methode ansehen
      </a>
    </div>
  </section>

  <!-- 4. Proof -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Was dabei entsteht
      </p>
      <h2 class="font-display mb-16 max-w-2xl text-3xl font-semibold leading-tight md:text-4xl">
        Sichtbarkeit, die sich in Ergebnissen zeigt.
      </h2>
      <div class="grid gap-px bg-white/10 md:grid-cols-3">
        {
          outcomes.map((o) => (
            <div class="bg-black p-8 md:p-12">
              <p class="font-display text-2xl font-semibold text-brand-green md:text-3xl">{o}</p>
            </div>
          ))
        }
      </div>
      <a href="/referenzen" class="mt-12 inline-block text-sm font-semibold text-brand-green hover:underline">
        Referenzen ansehen
      </a>
    </div>
  </section>

  <!-- 5. Value-Content -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <div class="grid items-center gap-14 md:grid-cols-2 md:gap-20">
        <div>
          <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
            Aus unseren Videos
          </p>
          <h2 class="font-display mb-6 text-3xl font-semibold leading-tight md:text-4xl">
            Wir predigen nichts, was wir nicht selbst tun.
          </h2>
          <p class="mb-8 text-lg leading-relaxed text-white/55">
            Auf unserem YouTube-Kanal zeigen wir offen, wie wir denken,
            produzieren und Sichtbarkeit aufbauen. Schau vorbei und mach dir
            selbst ein Bild.
          </p>
          <a
            href={social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block text-sm font-semibold text-brand-green hover:underline"
          >
            Zum Kanal
          </a>
        </div>
        <YouTubeEmbed id="dQw4w9WgXcQ" title="Consistent Media auf YouTube" />
      </div>
    </div>
  </section>

  <!-- 6. Wo stehst du? -->
  <section class="px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Wo stehst du?
      </p>
      <h2 class="font-display mb-16 max-w-2xl text-3xl font-semibold leading-tight md:text-4xl">
        Wie können wir dir helfen?
      </h2>
      <div class="grid gap-px bg-white/10 md:grid-cols-3">
        {
          paths.map((p) => (
            <a href={p.href} class="group flex flex-col gap-5 bg-black p-8 transition-colors hover:bg-white/[0.02] md:p-10">
              <h3 class="font-display text-xl font-semibold leading-snug">{p.title}</h3>
              <p class="leading-relaxed text-white/55">{p.text}</p>
              <span class="mt-auto pt-2 text-sm font-semibold text-brand-green">Mehr erfahren</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7. CTA -->
  <CTA
    title="Bereit, gesehen zu werden?"
    text="Alles, was du zum Selbermachen brauchst, zeigen wir offen. Wenn du es mit einem Team umsetzen willst, das es täglich tut, fülle das Formular aus und wir melden uns."
  />
</Layout>
