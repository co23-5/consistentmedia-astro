---
import Layout from "../layouts/Layout.astro";
import SpotlightCTA from "../components/SpotlightCTA.astro";
import DrehtageAnimation from "../components/DrehtageAnimation.astro";

const leistungen = [
  {
    nummer: "01",
    title: "Content: Die Basis",
    kurz: "Vertrauen, bevor der erste Kontakt entsteht",
    beschreibung:
      "Regelmäßiger Content zeigt echte Arbeit und echte Menschen dahinter. Welcher Kanal am besten zu dir passt, hängt von deiner Zielgruppe ab. Kunden vertrauen dir, bevor sie überhaupt anfragen.",
  },
  {
    nummer: "02",
    title: "Bezahlte Reichweite",
    kurz: "Vertrauen ausbauen, Ergebnisse beschleunigen",
    beschreibung:
      "Organische Reichweite baut Vertrauen auf, bezahlte Werbung beschleunigt das Ergebnis und erreicht gezielt die Richtigen. Wer dich schon kennt, fragt günstiger und qualifizierter an.",
  },
  {
    nummer: "03",
    title: "Backend: Das Nervensystem",
    kurz: "Damit kein Lead verloren geht",
    beschreibung:
      "Website, Landingpages und CRM sorgen dafür, dass jede Anfrage ankommt. Und: Kontrolle über die eigenen Daten, unabhängig von einzelnen Plattformen.",
  },
];

const referenzen = [
  {
    kunde: "Felix Zimmermann",
    branche: "Kälte- und Klimatechnik",
    foto: "/kunden/felix-zimmermann-waermepumpen-youtube-experte.jpg",
    ausgangslage:
      "Fachlich sehr stark, online kaum sichtbar. Viele Aufträge, aber nicht immer die richtigen.",
    ergebnis:
      "Bessere Vorqualifizierung, weniger Erklärungsaufwand im Vertrieb. YouTube als zentralen Vertrauensanker.",
  },
  {
    kunde: "Jürgen Melzener",
    branche: "Ganzheitliche Zahnmedizin",
    foto: "/kunden/juergen-melzener-zahnarzt-ganzheitlich-youtube.png",
    ausgangslage:
      "Sehr erklärungsbedürftiges Thema, viele Missverständnisse im Markt, hoher Vertrauensbedarf.",
    ergebnis:
      "YouTube als Plattform für Aufklärung und Vertrauen. Überregionale Nachfrage durch klare Positionierung.",
  },
];
---

<Layout
  title="Consistent Media"
  description="Traffic-Agentur für Unternehmer, die fachlich stark sind und online sichtbar werden wollen. Wir bauen Systeme aus YouTube-Content, Social Media, Paid Ads und digitalem Backend."
>
  <!-- 1. Hero: Studio-Video im Hintergrund -->
  <section class="relative -mt-[73px] flex min-h-[100svh] flex-col justify-end overflow-hidden pb-20 md:justify-center md:pb-24">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 hidden h-full w-full object-cover md:block"
    >
      <source src="/consistent-media-studio-header.mp4" type="video/mp4" />
    </video>
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
    >
      <source src="/consistent-media-studio-header-hochkant.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>

    <div class="relative mx-auto w-full max-w-content px-6 pt-[73px]">
      <h1
        id="hero-heading"
        class="font-display mb-8 font-bold leading-[1.05] tracking-tight"
        style="font-size: clamp(1.9rem, 6.5vw, 6.5rem);"
      >
        <span class="block whitespace-nowrap"
          ><span id="rotating-word" class="rotating-word text-brand-green">Expertise</span
          ><span class="caret text-brand-green" aria-hidden="true">|</span></span
        >
        <span class="block whitespace-nowrap">sichtbar machen.</span>
      </h1>
      <p class="mb-12 max-w-xl text-lg leading-relaxed text-white/70 md:text-xl">
        Du hast mehr Expertise als deine Konkurrenz?<br />Leider sieht das niemand.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/kontakt"
          class="border border-brand-green px-8 py-4 text-sm font-semibold text-brand-green backdrop-blur-sm transition-colors hover:bg-brand-green hover:text-black"
        >
          Zusammenarbeit anfragen
        </a>
        <a
          href="/leistungen"
          class="border border-white/30 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white/60"
        >
          Leistungen ansehen
        </a>
      </div>

      <DrehtageAnimation />
    </div>
  </section>

  <script>
    const words = ["Expertise", "Erfolge", "Angebote", "Leistungen", "Ergebnisse"];
    const el = document.getElementById("rotating-word");
    const heading = document.getElementById("hero-heading");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Eine feste Schriftgroesse fuers laengste Wort, damit sich die Groesse
    // beim Wortwechsel nie veraendert -- nur bei echter Fensterbreiten-Aenderung.
    const longestWord = words.reduce((a, b) => (b.length > a.length ? b : a));
    const measureCanvas = document.createElement("canvas");
    const measureCtx = measureCanvas.getContext("2d");
    const sizeToFit = () => {
      if (!heading || !measureCtx) return;
      const container = heading.parentElement;
      const maxWidth = (container ? container.clientWidth : window.innerWidth) * 0.98;
      const probe = 100;
      measureCtx.font = `700 ${probe}px ClashDisplay, sans-serif`;
      // Wort und "sichtbar machen." stehen jetzt auf eigenen Zeilen -- beide muessen
      // einzeln in die Breite passen, es zaehlt die breitere der beiden Zeilen.
      const wordWidth = measureCtx.measureText(longestWord).width;
      const secondLineWidth = measureCtx.measureText("sichtbar machen.").width;
      const textWidth = Math.max(wordWidth, secondLineWidth);
      let size = (maxWidth / textWidth) * probe;
      size = Math.max(22, Math.min(size, 88));
      heading.style.fontSize = `${size}px`;
    };
    sizeToFit();
    if (document.fonts) {
      document.fonts.ready.then(sizeToFit);
    }
    window.addEventListener("resize", sizeToFit);

    if (el && !reduce) {
      let wordIndex = 0;
      let charIndex = words[0].length; // startet mit voll gezeigtem "Expertise"
      let deleting = true;
      const tick = () => {
        const word = words[wordIndex];
        if (!deleting) {
          charIndex++;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === word.length) {
            deleting = true;
            setTimeout(tick, 1200); // Pause beim vollen Wort
            return;
          }
          setTimeout(tick, 85); // Tipptempo
        } else {
          charIndex--;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === 0) {
            deleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            document.dispatchEvent(new CustomEvent("cm:word-change"));
            setTimeout(tick, 350); // Pause vor dem naechsten Wort
            return;
          }
          setTimeout(tick, 40); // Löschtempo
        }
      };
      setTimeout(tick, 1800);
    }
  </script>

  <!-- 2. Warum + Wie: Customer-Golden-Circle als ein durchgehender Artikel -->
  <section class="relative overflow-hidden border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <span
      aria-hidden="true"
      class="font-display pointer-events-none absolute -top-10 -left-2 select-none text-[13rem] font-bold leading-none text-white/[0.04] md:-top-20 md:text-[24rem]"
    >
      ”
    </span>
    <div class="relative mx-auto max-w-content">
      <div data-fade-group class="mx-auto max-w-2xl space-y-6">
        <p class="fade-line text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
          Warum Sichtbarkeit zählt
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Gute Arbeit überzeugt nur die, die sie schon erlebt haben.
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Alle anderen sehen nur, was sichtbar ist.
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Deshalb gewinnen oft nicht die Besten.
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Sondern <span class="marker">die Sichtbarsten</span>.
        </p>

        <p class="fade-line pt-6 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
          Wie das gelingt
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Je mehr Wissen du hast, desto schwieriger ist es selber einzuschätzen, was für
          jemand anderen relevant ist.
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Was für dich selbstverständlich ist, bleibt für andere unsichtbar.
        </p>
        <p class="fade-line font-sans text-2xl font-semibold leading-snug text-white/80 md:text-3xl">
          Dein Wissen muss <span class="marker">in Inhalte übersetzt werden</span>, die
          deine Zielgruppe sofort versteht.
        </p>
      </div>
    </div>
  </section>

  <script>
    // Manifest-Zeilen (WHY/HOW): fade + slide, gestaffelt beim Einscrollen
    (() => {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      document.querySelectorAll<HTMLElement>("[data-fade-group]").forEach((group) => {
        const lines = group.querySelectorAll<HTMLElement>(".fade-line");
        if (reduce) {
          lines.forEach((l) => l.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                lines.forEach((l, i) => setTimeout(() => l.classList.add("is-visible"), i * 150));
                io.disconnect();
              }
            });
          },
          { threshold: 0.4 },
        );
        io.observe(group);
      });
    })();
  </script>

  <!-- 4. Was: Leistungen -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8">
    <div class="mx-auto max-w-content">
      <div class="mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
            Was getan werden muss
          </p>
          <h2 class="font-display max-w-xl text-4xl font-semibold leading-tight md:text-5xl">
            Dafür braucht es kein Sammelsurium an Kanälen. Sondern ein System, das
            ineinandergreift.
          </h2>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/55">
            Ads, Social Media oder eine neue Website funktionieren einzeln kaum. Erst im
            Zusammenspiel entsteht Vertrauen, das ankommt.
          </p>
        </div>
        <a
          href="/leistungen"
          class="shrink-0 text-sm font-medium text-white/50 underline underline-offset-4 hover:text-white"
        >
          Alle Leistungen
        </a>
      </div>

      <div class="grid gap-px bg-white/10 md:grid-cols-3">
        {
          leistungen.map(({ nummer, title, kurz, beschreibung }) => (
            <div class="flex flex-col gap-6 bg-black p-8 transition-colors hover:bg-white/[0.03]">
              <span class="font-display text-sm font-medium text-white/20">{nummer}</span>
              <div>
                <h3 class="font-display text-2xl font-semibold">{title}</h3>
                <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-brand-green">
                  {kurz}
                </p>
              </div>
              <p class="text-sm leading-relaxed text-white/55">{beschreibung}</p>
            </div>
          ))
        }
      </div>

      <p class="mt-12 font-display text-2xl font-bold leading-tight md:text-3xl">
        Der Schlüssel liegt im Zusammenspiel.
      </p>
    </div>
  </section>

  <!-- 3. Referenzen-Teaser -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8">
    <div class="mx-auto max-w-content">
      <div class="mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
            Referenzen
          </p>
          <h2 class="font-display max-w-lg text-4xl font-semibold leading-tight md:text-5xl">
            Expertise sichtbar gemacht.
          </h2>
        </div>
        <a
          href="/referenzen"
          class="shrink-0 text-sm font-medium text-white/50 underline underline-offset-4 hover:text-white"
        >
          Alle Referenzen
        </a>
      </div>

      <div class="grid gap-px bg-white/10 md:grid-cols-2">
        {
          referenzen.map(({ kunde, branche, foto, ausgangslage, ergebnis }) => (
            <div class="flex flex-col gap-6 bg-black p-8 transition-colors hover:bg-white/[0.03] md:p-10">
              <div class="flex items-center gap-4">
                <img
                  src={foto}
                  alt={kunde}
                  width="48"
                  height="48"
                  class="h-12 w-12 rounded-full object-cover"
                />
                <div>
                  <p class="font-display text-xl font-semibold">{kunde}</p>
                  <p class="mt-0.5 text-xs font-semibold uppercase tracking-widest text-white/50">
                    {branche}
                  </p>
                </div>
              </div>

              <div class="flex flex-col gap-4 border-t border-white/10 pt-6">
                <div>
                  <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-white/50">
                    Ausgangslage
                  </p>
                  <p class="text-sm leading-relaxed text-white/60">{ausgangslage}</p>
                </div>
                <div>
                  <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-brand-green">
                    Ergebnis
                  </p>
                  <p class="text-sm leading-relaxed text-white/80">{ergebnis}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. CTA: Spotlight -->
  <SpotlightCTA />
</Layout>
