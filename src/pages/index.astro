---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";

// Aufwand-Vergleich: gleicher Umsatz, sehr unterschiedlicher Aufwand.
// Kreise = Aufwand (Mitarbeiter, Arbeitsmittel, Zeit ...), Rechteck = Umsatz.
const aufwandPasst = 8;
const aufwandPasstNicht = 14;
---

<Layout
  title="Consistent Media"
  description="Die Besten sollten gewinnen, nicht die Lautesten. Wir machen echte Expertise sichtbar, über YouTube, Content und Ads."
>
  <!-- 1. Hero: das Warum, mit Studio-Video im Hintergrund -->
  <section class="relative -mt-[73px] flex min-h-[100svh] flex-col justify-center overflow-hidden border-b border-white/10 px-6 pb-24 pt-[73px] md:px-8">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 hidden h-full w-full object-cover md:block"
    >
      <source src="/consistent-media-studio-header.mp4" type="video/mp4" />
    </video>
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
    >
      <source src="/consistent-media-studio-header-hochkant.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/40"></div>

    <div class="relative mx-auto w-full max-w-content text-center">
      <h1 class="font-display font-bold leading-[1.05] tracking-tight text-[clamp(1.9rem,8vw,4.5rem)]">
        <span class="whitespace-nowrap"><span id="rotating-word" class="rotating-word text-brand-green"
            >Expertise</span
          ><span class="caret text-brand-green" aria-hidden="true">|</span></span
        >
        <br />sichtbar machen.
      </h1>
      <div class="mt-14 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/kontakt"
          class="border border-brand-green bg-brand-green px-8 py-4 text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          Zusammenarbeit anfragen
        </a>
        <a
          href="/methode"
          class="border border-white/40 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white/70"
        >
          So funktioniert es
        </a>
      </div>
    </div>
  </section>

  <script>
    const words = [
      "Expertise",
      "Einzigartigkeit",
      "Unternehmenserfolge",
      "Arbeitgebermarke",
      "Angebote",
    ];
    const el = document.getElementById("rotating-word");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (el && !reduce) {
      let wordIndex = 0;
      let charIndex = words[0].length; // startet mit voll gezeigtem "Expertise"
      let deleting = true;
      const tick = () => {
        const word = words[wordIndex];
        if (!deleting) {
          charIndex++;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === word.length) {
            deleting = true;
            setTimeout(tick, 1200); // Pause beim vollen Wort
            return;
          }
          setTimeout(tick, 85); // Tipptempo
        } else {
          charIndex--;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === 0) {
            deleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            setTimeout(tick, 350); // Pause vor dem nächsten Wort
            return;
          }
          setTimeout(tick, 40); // Löschtempo
        }
      };
      setTimeout(tick, 1800);
    }
  </script>

  <!-- 2. Manifest: das Herzstück, auf Notizblock-Raster -->
  <section class="paper-grid border-b border-white/10 px-6 py-28 md:px-8 md:py-40">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display mb-10 text-4xl font-semibold leading-tight md:text-5xl">
        Warum das alles?
      </h2>
      <div class="space-y-8 text-xl leading-relaxed text-white/70 md:text-2xl md:leading-relaxed">
        <p>
          Viele Unternehmen haben geniale Lösungen für unterschiedlichste
          Probleme, die von tollen Menschen umgesetzt werden. Das Problem? Man
          muss das Glück haben, sie persönlich zu kennen oder empfohlen bekommen
          zu haben, da sie online entweder nicht aufzufinden sind oder der
          Online-Auftritt schlicht und einfach nichtssagend ist.
        </p>
        <p>Deshalb ist unsere Mission:</p>
      </div>
      <p class="font-display mt-10 whitespace-nowrap font-semibold leading-none text-[clamp(1.35rem,6vw,3.25rem)]">
        Expertise <span class="reveal-word text-brand-green">sichtbar</span> machen.
      </p>
    </div>
  </section>

  <script>
    const word = document.querySelector(".reveal-word");
    if (word) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              word.classList.add("is-visible");
              io.disconnect();
            }
          });
        },
        { threshold: 0.6 },
      );
      io.observe(word);
    }
  </script>

  <!-- 2b. Du kennst das: gleiches Ergebnis, mehr Aufwand -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Du kennst das
      </p>
      <h2 class="font-display mb-6 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
        Manche <span class="whitespace-nowrap"><span id="kennst-word" class="text-brand-green">Produkte</span><span class="caret text-brand-green" aria-hidden="true">|</span></span><br />bringen mehr Umsatz als andere.
      </h2>
      <p class="mb-16 max-w-xl text-lg leading-relaxed text-white/55">
        Aber du hast nicht genug davon, um die anderen Aufträge einfach
        abzulehnen. Also nimmst du sie an.
      </p>

      <div id="cost-compare" class="grid gap-px bg-white/10 md:grid-cols-2">
        <div class="flex flex-col bg-black p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">
            Passende Aufträge
          </p>
          <div class="mb-12 mt-8 flex max-w-52 flex-wrap gap-3">
            {
              Array.from({ length: aufwandPasst }).map(() => (
                <span class="effort-dot inline-block h-5 w-5">
                  <span class="dot-inner block h-full w-full rounded-full bg-white/40" />
                </span>
              ))
            }
          </div>
          <div class="mt-auto border border-brand-green/40 bg-brand-green/10 px-6 py-5">
            <p class="font-display text-3xl font-semibold text-brand-green md:text-4xl">
              1.000.000 €
            </p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-white/50">
              Umsatz
            </p>
          </div>
        </div>

        <div class="flex flex-col bg-black p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">
            Unpassende Aufträge
          </p>
          <div class="mb-12 mt-8 flex max-w-52 flex-wrap gap-3">
            {
              Array.from({ length: aufwandPasstNicht }).map(() => (
                <span class="effort-dot inline-block h-5 w-5">
                  <span class="dot-inner block h-full w-full rounded-full bg-white/40" />
                </span>
              ))
            }
          </div>
          <div class="mt-auto border border-brand-green/40 bg-brand-green/10 px-6 py-5">
            <p class="font-display text-3xl font-semibold text-brand-green md:text-4xl">
              1.000.000 €
            </p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-white/50">
              Umsatz
            </p>
          </div>
        </div>
      </div>

      <p class="mt-12 font-display text-2xl font-bold leading-tight md:text-3xl">
        Gleiches Ergebnis, unterschiedlicher Aufwand.
      </p>
    </div>
  </section>

  <script>
    // Typewriter fuer "Du kennst das"
    (() => {
      const words = ["Produkte", "Kunden", "Dienstleistungen"];
      const el = document.getElementById("kennst-word");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!el || reduce) return;
      let wi = 0,
        ci = words[0].length,
        del = true;
      const tick = () => {
        const w = words[wi];
        if (!del) {
          ci++;
          el.textContent = w.slice(0, ci);
          if (ci === w.length) {
            del = true;
            setTimeout(tick, 1200);
            return;
          }
          setTimeout(tick, 85);
        } else {
          ci--;
          el.textContent = w.slice(0, ci);
          if (ci === 0) {
            del = false;
            wi = (wi + 1) % words.length;
            setTimeout(tick, 350);
            return;
          }
          setTimeout(tick, 40);
        }
      };
      setTimeout(tick, 1800);
    })();

    // Aufwand-Kreise poppen beim Einscrollen rein
    (() => {
      const cmp = document.getElementById("cost-compare");
      if (!cmp) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              cmp.querySelectorAll(".effort-dot").forEach((d, i) => {
                setTimeout(() => d.classList.add("is-visible"), i * 55);
              });
              io.disconnect();
            }
          });
        },
        { threshold: 0.35 },
      );
      io.observe(cmp);
    })();
  </script>

  <!-- 2c. Das Ziel -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Das Ziel
      </p>
      <h2 class="font-display mb-16 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
        Online wahrgenommen werden und die richtigen Menschen anziehen.
      </h2>
      <div id="vorher-nachher" class="grid gap-px bg-white/10 md:grid-cols-2">
        <div class="bg-black p-8 md:p-10">
          <p class="mb-10 text-xs font-semibold uppercase tracking-widest text-white/40">
            Vorher
          </p>
          <div class="space-y-8">
            <div class="flex items-end justify-between gap-4">
              <span class="flex items-center gap-3 text-sm text-white/55">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7.5 12 13l9-5.5" />
                </svg>
                Anfragen
              </span>
              <span class="counter font-display text-4xl font-semibold tabular-nums md:text-5xl" data-target="42" data-duration="4200">0</span>
            </div>
            <div class="flex items-end justify-between gap-4">
              <span class="text-sm text-white/55">davon passend</span>
              <span class="counter font-display text-4xl font-semibold tabular-nums text-brand-green md:text-5xl" data-target="3" data-duration="4200">0</span>
            </div>
          </div>
        </div>

        <div class="bg-black p-8 md:p-10">
          <p class="mb-10 text-xs font-semibold uppercase tracking-widest text-brand-green">
            Nachher
          </p>
          <div class="space-y-8">
            <div class="flex items-end justify-between gap-4">
              <span class="flex items-center gap-3 text-sm text-white/55">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7.5 12 13l9-5.5" />
                </svg>
                Anfragen
              </span>
              <span class="counter font-display text-4xl font-semibold tabular-nums md:text-5xl" data-target="58" data-duration="3000">0</span>
            </div>
            <div class="flex items-end justify-between gap-4">
              <span class="text-sm text-white/55">davon passend</span>
              <span class="counter font-display text-4xl font-semibold tabular-nums text-brand-green md:text-5xl" data-target="31" data-duration="1900">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Vorher/Nachher: Zahlen zaehlen hoch (Anfragen + davon passend)
    (() => {
      const cont = document.getElementById("vorher-nachher");
      if (!cont) return;
      const counters = cont.querySelectorAll<HTMLElement>(".counter");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const setFinal = () => {
        counters.forEach((el) => {
          el.textContent = String(el.dataset.target ?? "0");
        });
      };

      if (reduce) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              setFinal();
              io.disconnect();
            }
          });
        });
        io.observe(cont);
        return;
      }

      const run = () => {
        counters.forEach((el) => {
          const target = Number(el.dataset.target ?? 0);
          const dur = Number(el.dataset.duration ?? 2000);
          const start = performance.now();
          const step = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.round(eased * target));
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        });
      };

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              run();
              setInterval(() => {
                counters.forEach((el) => (el.textContent = "0"));
                run();
              }, 6000);
              io.disconnect();
            }
          });
        },
        { threshold: 0.4 },
      );
      io.observe(cont);
    })();
  </script>

  <!-- 7. CTA -->
  <CTA title="Bereit, deine Expertise sichtbar zu machen?" text="" />
</Layout>
