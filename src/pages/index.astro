---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Consistent Media">
  <section class="mx-auto flex min-h-screen max-w-content flex-col justify-center px-6">
    <p class="mb-6 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
      Astro-Relaunch
    </p>
    <h1 class="font-display text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl">
      Expertise <span class="text-brand-green">sichtbar</span> machen.
    </h1>
    <p class="mt-8 max-w-xl text-lg leading-relaxed text-white/60 md:text-xl">
      Fundament steht. Ab hier bauen wir die Startseite nach der Journey auf.
    </p>
  </section>
</Layout>
