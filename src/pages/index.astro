---
import Layout from "../layouts/Layout.astro";
import SpotlightCTA from "../components/SpotlightCTA.astro";

// Aufwand-Vergleich: gleicher Umsatz, sehr unterschiedlicher Aufwand.
// Kreise = Aufwand (Mitarbeiter, Arbeitsmittel, Zeit ...), Rechteck = Umsatz.
const aufwandPasst = 8;
const aufwandPasstNicht = 14;
---

<Layout
  title="Consistent Media"
  description="Damit die richtigen Kunden anfragen und die richtigen Mitarbeiter sich bei dir bewerben. Wir machen deine Expertise sichtbar, über YouTube, Content und Ads."
>
  <!-- 1. Hero: das Warum, mit Studio-Video im Hintergrund -->
  <section class="relative -mt-[73px] flex min-h-[100svh] flex-col justify-center overflow-hidden border-b border-white/10 px-6 pb-24 pt-[73px] md:px-8">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 hidden h-full w-full object-cover md:block"
    >
      <source src="/consistent-media-studio-header.mp4" type="video/mp4" />
    </video>
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/consistent-media-studio-header-fallback.jpg"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
    >
      <source src="/consistent-media-studio-header-hochkant.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/40"></div>

    <div class="relative mx-auto w-full max-w-content text-center">
      <h1
        id="hero-heading"
        class="font-display whitespace-nowrap font-bold leading-[1.05] tracking-tight"
        style="font-size: clamp(1.7rem, 6vw, 4.5rem);"
      >
        <span id="rotating-word" class="rotating-word text-brand-green">Expertise</span
        ><span class="caret text-brand-green" aria-hidden="true">|</span> sichtbar machen.
      </h1>
      <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed text-white/60 md:text-xl">
        Damit die richtigen Kunden anfragen und die passenden Mitarbeiter sich bei dir bewerben.
      </p>
      <div class="mt-14 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/kontakt"
          class="border border-brand-green bg-brand-green px-8 py-4 text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          Zusammenarbeit anfragen
        </a>
        <a
          href="/methode"
          class="border border-white/40 px-8 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white/70"
        >
          So funktioniert es
        </a>
      </div>
    </div>
  </section>

  <script>
    const words = [
      "Expertise",
      "Einzigartigkeit",
      "Unternehmenserfolge",
      "Arbeitgebermarke",
      "Angebote",
    ];
    const el = document.getElementById("rotating-word");
    const heading = document.getElementById("hero-heading");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Eine feste Schriftgroesse fuers laengste Wort, damit sich die Groesse
    // beim Wortwechsel nie veraendert -- nur bei echter Fensterbreiten-Aenderung.
    const longestWord = words.reduce((a, b) => (b.length > a.length ? b : a));
    const measureCanvas = document.createElement("canvas");
    const measureCtx = measureCanvas.getContext("2d");
    const sizeToFit = () => {
      if (!heading || !measureCtx) return;
      const container = heading.parentElement;
      const maxWidth = (container ? container.clientWidth : window.innerWidth) * 0.98;
      const probe = 100;
      measureCtx.font = `700 ${probe}px ClashDisplay, sans-serif`;
      const textWidth = measureCtx.measureText(`${longestWord} sichtbar machen.`).width;
      let size = (maxWidth / textWidth) * probe;
      size = Math.max(22, Math.min(size, 88));
      heading.style.fontSize = `${size}px`;
    };
    sizeToFit();
    if (document.fonts) {
      document.fonts.ready.then(sizeToFit);
    }
    window.addEventListener("resize", sizeToFit);

    if (el && !reduce) {
      let wordIndex = 0;
      let charIndex = words[0].length; // startet mit voll gezeigtem "Expertise"
      let deleting = true;
      const tick = () => {
        const word = words[wordIndex];
        if (!deleting) {
          charIndex++;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === word.length) {
            deleting = true;
            setTimeout(tick, 1200); // Pause beim vollen Wort
            return;
          }
          setTimeout(tick, 85); // Tipptempo
        } else {
          charIndex--;
          el.textContent = word.slice(0, charIndex);
          if (charIndex === 0) {
            deleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            setTimeout(tick, 350); // Pause vor dem naechsten Wort
            return;
          }
          setTimeout(tick, 40); // Löschtempo
        }
      };
      setTimeout(tick, 1800);
    }
  </script>

  <!-- 2. Der Hebel: Sichtbarkeit -- Kunden und Mitarbeiter landen im Unternehmen -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Der Hebel: Sichtbarkeit
      </p>
      <h2 class="font-display mb-6 max-w-2xl text-3xl font-semibold leading-tight md:text-4xl">
        Neue Kunden. Und Mitarbeiter, die die Arbeit erledigen.
      </h2>
      <p class="mb-16 max-w-2xl text-lg leading-relaxed text-white/55">
        Sichtbarkeit ist dafür der größte Hebel. Und er wird immer größer, je länger du
        sie aufbaust — genau wie das Vertrauen, das dabei entsteht.
      </p>

      <div class="mx-auto flex max-w-xs flex-col items-center">
        <div class="lever-stage relative h-48 w-full">
          {
            Array.from({ length: 12 }).map((_, i) => (
              <span
                class={`lever-dot ${i % 2 === 0 ? "lever-dot-kunde" : "lever-dot-mitarbeiter"}`}
                style={`--fx:${6 + i * 7.5}%; animation-delay:${i * 0.35}s;`}
              />
            ))
          }
        </div>
        <div class="lever-bucket relative -mt-px flex h-20 w-full items-start justify-center pt-5">
          <span class="text-xs font-semibold uppercase tracking-widest text-white/50">
            Unternehmen
          </span>
        </div>
      </div>

      <div class="mt-10 flex items-center justify-center gap-6 text-xs text-white/40">
        <span class="flex items-center gap-2">
          <span class="inline-block h-2 w-2 rounded-full bg-brand-green" aria-hidden="true"></span>
          Kunden
        </span>
        <span class="flex items-center gap-2">
          <span class="inline-block h-2 w-2 rounded-full bg-talent" aria-hidden="true"></span>
          Mitarbeiter
        </span>
      </div>
    </div>
  </section>

  <!-- 2b. Du kennst das: gleiches Ergebnis, mehr Aufwand -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Du kennst das
      </p>
      <h2 class="font-display mb-6 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
        Manche deiner <span class="whitespace-nowrap"><span id="kennst-word" class="text-brand-green">Kunden</span><span class="caret text-brand-green" aria-hidden="true">|</span></span><br />bringen mehr Umsatz als andere.
      </h2>
      <p class="mb-16 max-w-xl text-lg leading-relaxed text-white/55">
        Aber du hast nicht genug davon, um die anderen Aufträge einfach
        abzulehnen. Also nimmst du sie an.
      </p>

      <div id="cost-compare" class="grid gap-px bg-white/10 md:grid-cols-2">
        <div class="flex flex-col bg-black p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">
            Die richtigen Aufträge
          </p>
          <div class="mb-12 mt-8 flex max-w-52 flex-wrap gap-3">
            {
              Array.from({ length: aufwandPasst }).map(() => (
                <span class="effort-dot inline-block h-5 w-5">
                  <span class="dot-inner block h-full w-full rounded-full bg-effort" />
                </span>
              ))
            }
          </div>
          <div class="mt-auto border border-brand-green/40 bg-brand-green/10 px-6 py-5">
            <p class="font-display text-3xl font-semibold text-brand-green md:text-4xl">
              1.000.000 €
            </p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-white/50">
              Umsatz
            </p>
          </div>
        </div>

        <div class="flex flex-col bg-black p-8 md:p-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-white/50">
            Aufträge, die zu dir kommen
          </p>
          <div class="mb-12 mt-8 flex max-w-52 flex-wrap gap-3">
            {
              Array.from({ length: aufwandPasstNicht }).map(() => (
                <span class="effort-dot inline-block h-5 w-5">
                  <span class="dot-inner block h-full w-full rounded-full bg-effort" />
                </span>
              ))
            }
          </div>
          <div class="mt-auto border border-brand-green/40 bg-brand-green/10 px-6 py-5">
            <p class="font-display text-3xl font-semibold text-brand-green md:text-4xl">
              1.000.000 €
            </p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-white/50">
              Umsatz
            </p>
          </div>
        </div>
      </div>

      <p class="mt-8 flex items-center justify-center gap-2 text-xs text-white/40">
        <span class="inline-block h-2 w-2 rounded-full bg-effort" aria-hidden="true"></span>
        Aufwand — Mitarbeiter, Ressourcen, Zeit
      </p>

      <p class="mt-8 font-display text-2xl font-bold leading-tight md:text-3xl">
        Gleiches Ergebnis, unterschiedlicher Aufwand.
      </p>
    </div>
  </section>

  <script>
    // Typewriter fuer "Du kennst das"
    (() => {
      const words = ["Kunden", "Aufträge", "Dienstleistungen"];
      const el = document.getElementById("kennst-word");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!el || reduce) return;
      let wi = 0,
        ci = words[0].length,
        del = true;
      const tick = () => {
        const w = words[wi];
        if (!del) {
          ci++;
          el.textContent = w.slice(0, ci);
          if (ci === w.length) {
            del = true;
            setTimeout(tick, 1200);
            return;
          }
          setTimeout(tick, 85);
        } else {
          ci--;
          el.textContent = w.slice(0, ci);
          if (ci === 0) {
            del = false;
            wi = (wi + 1) % words.length;
            setTimeout(tick, 350);
            return;
          }
          setTimeout(tick, 40);
        }
      };
      setTimeout(tick, 1800);
    })();

    // Aufwand-Kreise poppen beim Einscrollen rein
    (() => {
      const cmp = document.getElementById("cost-compare");
      if (!cmp) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              cmp.querySelectorAll(".effort-dot").forEach((d, i) => {
                setTimeout(() => d.classList.add("is-visible"), i * 55);
              });
              io.disconnect();
            }
          });
        },
        { threshold: 0.35 },
      );
      io.observe(cmp);
    })();
  </script>

  <!-- 2c. Arbeitgebermarke -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Arbeitgebermarke
      </p>
      <h2 class="font-display mb-6 max-w-2xl text-3xl font-semibold leading-tight md:text-4xl">
        Gute Mitarbeiter wechseln nicht leichtfertig.
      </h2>
      <p class="mb-16 max-w-xl text-lg leading-relaxed text-white/55">
        Wer über einen Wechsel nachdenkt, wägt vor allem drei Dinge ab: das Gehalt,
        das Team und die Karrierechancen. Und selbst wenn bei dir alles davon besser
        wäre, wechselt niemand ins Ungewisse.
      </p>

      <div id="hire-scale" class="hire-scale mx-auto max-w-md pb-2 pt-6">
        <div class="relative mx-auto h-10 w-full max-w-sm">
          <div class="scale-beam absolute inset-x-0 top-1/2 h-[3px] bg-white/25"></div>
          <div class="absolute left-1/2 top-1/2 h-2.5 w-2.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/40"></div>
        </div>
        <div class="mt-3 flex items-start justify-between gap-6">
          <div class="scale-pan-left flex-1 border border-white/10 bg-black p-5 text-center">
            <p class="text-xs font-semibold uppercase tracking-widest text-white/50">
              Aktueller Job
            </p>
            <p class="mt-2 text-sm text-white/40">Bekannt. Sicher. Bequem.</p>
          </div>
          <div class="scale-pan-right flex-1 border border-brand-green/30 bg-brand-green/5 p-5 text-center">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-green">
              Bei dir
            </p>
            <ul class="mt-2 space-y-1 text-sm text-white/60">
              <li>Gehalt</li>
              <li>Team</li>
              <li>Karriere</li>
            </ul>
          </div>
        </div>
      </div>

      <p class="mt-12 font-display text-2xl font-bold leading-tight md:text-3xl">
        Sichtbarkeit schafft das Vertrauen, dass es bei dir wirklich besser ist.
      </p>
    </div>
  </section>

  <script>
    // Waage kippt beim Einscrollen von "Aktueller Job" zu "Bei dir"
    (() => {
      const el = document.getElementById("hire-scale");
      if (!el) return;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              setTimeout(() => el.classList.add("is-active"), 300);
              io.disconnect();
            }
          });
        },
        { threshold: 0.4 },
      );
      io.observe(el);
    })();
  </script>

  <!-- 2d. Das Ziel -->
  <section class="border-b border-white/10 px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-content">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
        Das Ziel
      </p>
      <h2 class="font-display mb-16 max-w-3xl text-3xl font-semibold leading-tight md:text-4xl">
        Die richtigen Menschen anziehen.
      </h2>
      <div id="vorher-nachher" class="grid gap-px bg-white/10 md:grid-cols-2">
        <div class="bg-black p-8 md:p-10">
          <p class="mb-10 text-xs font-semibold uppercase tracking-widest text-white/40">
            Vorher
          </p>
          <div class="space-y-8">
            <div class="flex items-end justify-between gap-4">
              <span class="flex items-center gap-3 text-sm text-white/55">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7.5 12 13l9-5.5" />
                </svg>
                Anfragen
              </span>
              <span class="counter font-display text-4xl font-semibold tabular-nums md:text-5xl" data-target="45" data-duration="24000">0</span>
            </div>
            <div class="flex items-end justify-between gap-4">
              <span class="text-sm text-white/55">davon passend</span>
              <span class="counter font-display text-4xl font-semibold tabular-nums text-brand-green md:text-5xl" data-target="5" data-duration="24000">0</span>
            </div>
          </div>
        </div>

        <div class="bg-black p-8 md:p-10">
          <p class="mb-10 text-xs font-semibold uppercase tracking-widest text-brand-green">
            Nachher
          </p>
          <div class="space-y-8">
            <div class="flex items-end justify-between gap-4">
              <span class="flex items-center gap-3 text-sm text-white/55">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7.5 12 13l9-5.5" />
                </svg>
                Anfragen
              </span>
              <span class="counter font-display text-4xl font-semibold tabular-nums md:text-5xl" data-target="180" data-duration="24000">0</span>
            </div>
            <div class="flex items-end justify-between gap-4">
              <span class="text-sm text-white/55">davon passend</span>
              <span class="counter font-display text-4xl font-semibold tabular-nums text-brand-green md:text-5xl" data-target="150" data-duration="24000">0</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Vorher/Nachher: Zahlen zaehlen hoch (Anfragen + davon passend)
    (() => {
      const cont = document.getElementById("vorher-nachher");
      if (!cont) return;
      const counters = cont.querySelectorAll<HTMLElement>(".counter");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const setFinal = () => {
        counters.forEach((el) => {
          el.textContent = String(el.dataset.target ?? "0");
        });
      };

      if (reduce) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              setFinal();
              io.disconnect();
            }
          });
        });
        io.observe(cont);
        return;
      }

      const run = () => {
        counters.forEach((el) => {
          const target = Number(el.dataset.target ?? 0);
          const dur = Number(el.dataset.duration ?? 2000);
          const start = performance.now();
          const step = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            el.textContent = String(Math.round(p * target));
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        });
      };

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              run();
              setInterval(() => {
                counters.forEach((el) => (el.textContent = "0"));
                run();
              }, 27000);
              io.disconnect();
            }
          });
        },
        { threshold: 0.4 },
      );
      io.observe(cont);
    })();
  </script>

  <!-- 7. CTA: Spotlight -->
  <SpotlightCTA />
</Layout>
