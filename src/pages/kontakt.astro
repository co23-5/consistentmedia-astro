---
import Layout from "../layouts/Layout.astro";
import KontaktFormular from "../components/KontaktFormular.astro";
---

<Layout
  title="Zusammenarbeit anfragen"
  description="Wir arbeiten mit einer begrenzten Anzahl an Kunden. Schildere uns dein Vorhaben, passt es, melden wir uns für ein persönliches Gespräch."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-content">
      <div class="grid gap-20 md:grid-cols-2">
        <!-- Info -->
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-brand-green">
            Zusammenarbeit
          </p>
          <h1 class="font-display mb-12 text-4xl font-semibold leading-tight md:text-5xl">
            Lass uns über eine Zusammenarbeit sprechen.
          </h1>

          <div class="flex flex-col gap-8 border-t border-white/10 pt-10">
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-brand-green">
                Wie es weitergeht
              </p>
              <p class="text-sm leading-relaxed text-white/60">
                Wir sichten jede Anfrage persönlich. Passt es, melden wir uns für
                ein Gespräch, in dem wir Ziele, Aufwand und Zusammenarbeit klären.
              </p>
            </div>
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-brand-green">
                Mit wem wir arbeiten
              </p>
              <p class="text-sm leading-relaxed text-white/60">
                Mit Menschen, die fachlich stark sind und bereit, kontinuierlich
                sichtbar zu werden. Eine ehrliche Einschätzung bekommst du in jedem
                Fall.
              </p>
            </div>
            <div class="flex flex-col gap-4 border-t border-white/10 pt-8">
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-white/50">
                  E-Mail
                </p>
                <a
                  href="mailto:kontakt@consistentmedia.de"
                  class="text-white transition-colors hover:text-brand-green"
                >
                  kontakt@consistentmedia.de
                </a>
              </div>
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-white/50">
                  Antwortzeit
                </p>
                <p class="text-white/70">Innerhalb von 24 Stunden</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Formular -->
        <KontaktFormular />
      </div>
    </div>
  </section>
</Layout>
